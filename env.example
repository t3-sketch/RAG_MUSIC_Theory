# Anthropic API（必須）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 使用する Claude モデル（任意・デフォルトは claude-sonnet-4-6）
# 高品質重視なら claude-opus-4-8 / 低コスト重視なら claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# 埋め込みモデル（任意・デフォルトは BGE-M3）
EMBED_MODEL=BAAI/bge-m3

# Songle API トークン（任意・Songle を使う場合のみ）
SONGLE_API_TOKEN=
